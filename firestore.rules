
/**
 * Core Philosophy: This ruleset enforces a strict user-ownership model for all private data,
 * ensuring that users can only access their own profiles and activity logs. Publicly shared
 * data, such as skills, fireteams, and territories is readable by anyone to facilitate discovery and
 * community interaction, but write access is tightly controlled.
 *
 * Data Structure:
 * - /users/{userId} - Contains a user's private profile. This path forms the root for all user-owned data.
 * - /users/{userId}/logs/{logId} - A subcollection storing a user's private activity logs.
 * - /skills/{skillId} - A top-level collection of all skills, which are public to read.
 * - /fireteams/{fireteamId} - A top-level collection of all fireteams, which are public to read.
 * - /fireteams/{fireteamId}/messages/{messageId} - A subcollection for fireteam chat messages.
 * - /users/{userId}/quests/{questId} - A subcollection storing a user's private quests.
 * - /territories/{territoryId} - A top-level collection of all territories, which are public to read.
 * - /traits/{traitId} - A top-level collection for global trait definitions.
 * - /guilds/{guildId} - A top-level collection for user-run communities.
 *
 * Key Security Decisions:
 * - User data is strictly private. All documents and subcollections under /users/{userId} are
 *   accessible only by the authenticated user whose UID matches {userId}.
 * - User listing is allowed for counting but not reading individual docs. To protect user privacy,
 *   it is not possible to get a document from the top-level /users collection unless you are the owner.
 * - Public data write access is restricted. Anyone can read /skills, /fireteams and /territories, but creating
 *   or modifying them requires specific permissions.
 * - Default posture is deny-all. Access is only granted through explicit `allow` statements.
 *
 * Denormalization for Authorization:
 * - Skill Ownership: Each document in the `/skills` collection must contain a `pioneerUserId` field.
 *   This denormalized field allows rules to grant write access to the skill's creator without
 *   needing to perform extra document reads.
 * - Log Ownership: Documents in `/users/{userId}/logs/{logId}` contain a `userId` field that must
 *   match the path, ensuring data integrity and simplifying ownership checks for collection group queries.
 * - Fireteam Membership: The `members` map in `/fireteams/{fireteamId}` allows for checking if a
 *   user is part of a team without a separate document read, crucial for the 'Soul Link' mechanic.
 * - Guild Membership: The `members` map in `/guilds/{guildId}` and the `guilds` map on a user document
 *   allow for checking guild membership without extra reads.
 *
 * Structural Segregation:
 * - The ruleset leverages a clear separation between private and public data. User-specific,
 *   private data (`users`, `logs`, `quests`) is nested under a user-owned path. Publicly accessible data
 *   (`skills`, `fireteams`, `territories`, `traits`, `guilds`) is stored in top-level collections, which is more secure and performant
 *   for public list operations.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions to improve readability and maintainability.

    /**
     * Checks if a user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user's UID matches the provided userId.
     * This is the primary function for verifying document ownership.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks for ownership on an existing document. Used for safe updates and deletes.
     * Prevents modifying or deleting documents that do not exist.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }
    
    /**
     * Checks if the requesting user is a member of the fireteam specified in the resource.
     */
    function isFireteamMember() {
      return isSignedIn() && resource.data.members[request.auth.uid] == true;
    }
    
    /**
     * Checks if the requesting user is a member of the guild specified in the resource,
     * by looking at the user's own document.
     */
    function isGuildMember(guildId) {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.guilds[guildId] == true;
    }
    
    /**
     * Checks if the user has the 'isAdmin' flag set to true on their user document.
     * Uses .get() with a default value to prevent errors on non-existent fields.
     */
    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true;
    }

    /**
     * @description   User profile data. A user can create their own profile and has
     *                full control over it. No other user can read or write to it.
     * @path          /users/{userId}
     * @allow         (create) An authenticated user creating their own user document: request.auth.uid == userId.
     * @deny          (get) An authenticated user trying to read another user's profile.
     * @principle     Restricts access to a user's own data tree and prevents user enumeration.
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      // Allow anyone to perform a list for counting, but not read individual docs.
      allow list: if true;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      // Allow updates by the owner or an admin. Admins can only update specific fields.
      allow update: if isOwner(userId) || 
                    (isAdmin() && (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isAdmin', 'userName', 'gems']))) ||
                    (request.resource.data.keys().hasOnly(['traits', 'innovatorAwarded']));
      allow delete: if isExistingOwner(userId) || isAdmin();

      /**
       * @description   User activity logs. These are private and nested under the user's
       *                document, inheriting the same ownership-based security.
       * @path          /users/{userId}/logs/{logId}
       * @allow         (create) An authenticated user creating a log in their own subcollection.
       * @deny          (list) A user trying to list logs belonging to another user.
       * @principle     Enforces document ownership for a user's private subcollections.
       */
      match /logs/{logId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if (isExistingOwner(userId) || isAdmin()) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId) || isAdmin();
      }
      
      /**
       * @description   User quests. These are private and can only be managed by the user.
       * @path          /users/{userId}/quests/{questId}
       * @allow         (create, list) An authenticated user managing quests in their own subcollection.
       * @deny          (update, delete) A user trying to modify quests belonging to another user.
       * @principle     Enforces document ownership for a user's private quests.
       */
      match /quests/{questId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if (isExistingOwner(userId) || isAdmin()) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId) || isAdmin();
      }
    }

    /**
     * @description   Skills are public and can be read by anyone, but can only be created,
     *                updated, or deleted by the original "pioneer" user or an admin.
     * @path          /skills/{skillId}
     * @allow         (get) Any user (authenticated or not) reading a skill document.
     * @deny          (update) A user trying to modify a skill they did not create.
     * @principle     Public Read with Owner-Only Writes, based on a denormalized 'pioneerUserId' field.
     */
    match /skills/{skillId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.pioneerUserId == request.auth.uid;
      // Allow pioneer or admin to update.
      allow update: if (isExistingOwner(resource.data.pioneerUserId) && request.resource.data.pioneerUserId == resource.data.pioneerUserId) || isAdmin() || (request.resource.data.keys().hasAll(['xp', 'innovatorAwarded']));
      allow delete: if isExistingOwner(resource.data.pioneerUserId) || isAdmin();
    }

    /**
     * @description   Fireteams are public and can be read by anyone. Writes are restricted
     *                to the owner or admins.
     * @path          /fireteams/{fireteamId}
     * @allow         (create) Any authenticated user can create a fireteam, becoming its owner.
     * @deny          (update) A user trying to modify a fireteam they do not own.
     * @principle     Public Read with Owner-Only Writes, based on a denormalized 'ownerId' field.
     */
    match /fireteams/{fireteamId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      // Allow owner or members to update (for streak logic)
      allow update: if isExistingOwner(resource.data.ownerId) || isFireteamMember() || isAdmin();
      allow delete: if isExistingOwner(resource.data.ownerId) || isAdmin();

      /**
       * @description   Fireteam chat messages. Only members of the fireteam can read and write.
       * @path          /fireteams/{fireteamId}/messages/{messageId}
       * @allow         (read, write) A user who is a member of the parent fireteam document.
       * @deny          (all) Any user who is not a member of the fireteam.
       * @principle     Scoped access based on a parent document's data using `get()`.
       */
      match /messages/{messageId} {
        allow read, write: if isSignedIn() 
                        && get(/databases/$(database)/documents/fireteams/$(fireteamId)).data.members[request.auth.uid] == true;
        allow delete: if isAdmin();
      }
    }
    
    /**
     * @description   Guilds are public communities. Anyone can read them. Updates are restricted.
     * @path          /guilds/{guildId}
     * @allow         (update) A member can update their own membership status.
     * @principle     Public read, with restricted, logical writes. Creation is handled server-side.
     */
    match /guilds/{guildId} {
        allow get, list: if isSignedIn();
        // Disallow client-side creation. Admins or server logic handle this.
        allow create: if isAdmin(); 
        // Allow members to update their own membership status or for admins to manage.
        allow update: if isGuildMember(guildId) || isAdmin() || request.resource.data.keys().hasAny(['challengeProgress', 'isBuffActive', 'challengeEndsAt']);
        // Only admins can delete guilds.
        allow delete: if isAdmin();
        
        /**
         * @description   Guild chat messages. Only members of the guild can read and write.
         * @path          /guilds/{guildId}/messages/{messageId}
         * @allow         (read, write) A user who is a member of the parent guild document.
         * @deny          (all) Any user who is not a member of the guild.
         * @principle     Scoped access based on a parent document's data using `get()`.
         */
        match /messages/{messageId} {
            allow read: if isGuildMember(guildId);
            allow write: if isGuildMember(guildId) 
                            && request.resource.data.userId == request.auth.uid
                            && request.resource.data.channel is string;
            allow delete: if isAdmin();
        }
    }
    
    /**
     * @description   Territories are public to read for all users. Writes are restricted.
     * @path          /territories/{territoryId}
     * @allow         (get, list) Any authenticated user can read territory data.
     * @deny          (write) Writes are admin only.
     * @principle     Public Read for a global game state feature.
     */
    match /territories/{territoryId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }
    
    /**
     * @description   Global Trait definitions are public to read for all users. Writes are admin only.
     * @path          /traits/{traitId}
     * @allow         (read) Any authenticated user can read trait definitions.
     * @deny          (write) Writes are disallowed to maintain integrity.
     * @principle     Public Read for global game definitions.
     */
    match /traits/{traitId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }
    
    /**
     * @description   Suggestions from users. Any signed-in user can submit one. Admins manage them.
     * @path          /suggestions/{suggestionId}
     * @principle     Allow public write for feedback, but restrict read/update/delete to admins.
     */
    match /suggestions/{suggestionId} {
        allow get, list: if isAdmin();
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isAdmin();
    }

    /**
     * @description   Global events are public to read for all users. Writes are restricted to admins.
     * @path          /events/{eventId}
     * @principle     Public Read for global game state, with admin-only writes.
     */
    match /events/{eventId} {
        allow get, list: if true; 
        allow write: if isAdmin();
    }

    /**
     * @description   Store items are public to read for all users. Writes are restricted to admins.
     * @path          /store-items/{itemId}
     * @principle     Public Read for store content, with admin-only writes.
     */
    match /store-items/{itemId} {
        allow get, list: if isSignedIn();
        allow write: if isAdmin();
    }
  }
}

