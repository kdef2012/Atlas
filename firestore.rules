
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // WARNING: These rules are insecure and for development only.
      // They allow anyone, authenticated or not, to read and write to your entire database.
      // Re-enable security rules before going to production.
      allow read, write: if true;
    }
  }
}
