rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // HELPER FUNCTIONS
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isFireteamMember(fireteamId) {
      return isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/fireteams/$(fireteamId)).data.members;
    }

    function isGuildMember(guildId) {
      return isSignedIn() && guildId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.guilds;
    }

    // ADMINS COLLECTION
    match /admins/{adminId} {
      allow read: if isOwner(adminId) || isAdmin();
      allow write: if isAdmin() || isOwner(adminId);
    }
    
    // USERS COLLECTION
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      // USER SUB-COLLECTIONS
      match /{subcollection}/{docId} {
        allow get: if isOwner(userId) || isAdmin();
        allow list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) || isAdmin();
        allow update: if isOwner(userId) || isAdmin();
        allow delete: if isOwner(userId) || isAdmin();
      }
    }

    // PUBLIC LOGS COLLECTION
    match /public-logs/{logId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn(); 
      allow update: if false;
      allow delete: if false;
    }

    // SKILLS COLLECTION
    match /skills/{skillId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // VERIFICATIONS COLLECTION
    match /verifications/{verificationId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }
    
    // ACTIVITIES COLLECTION
    match /activities/{activityId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // FIRETEAMS COLLECTION
    match /fireteams/{fireteamId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isFireteamMember(fireteamId) || isAdmin();
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow get: if isFireteamMember(fireteamId) || isAdmin();
        allow list: if isFireteamMember(fireteamId) || isAdmin();
        allow create: if isFireteamMember(fireteamId);
        allow update: if isFireteamMember(fireteamId) || isAdmin();
        allow delete: if isAdmin();
      }
    }

    // GUILDS COLLECTION
    match /guilds/{guildId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isGuildMember(guildId) || isAdmin();
      allow delete: if isAdmin();
      
      match /messages/{messageId} {
        allow get: if isGuildMember(guildId) || isAdmin();
        allow list: if isGuildMember(guildId) || isAdmin();
        allow create: if isGuildMember(guildId);
        allow update: if isGuildMember(guildId) || isAdmin();
        allow delete: if isAdmin();
      }
    }

    // TERRITORIES COLLECTION
    match /territories/{territoryId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // TRAITS COLLECTION
    match /traits/{traitId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // SUGGESTIONS COLLECTION
    match /suggestions/{suggestionId} {
      allow get: if isAdmin();
      allow list: if isAdmin();
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // EVENTS COLLECTION
    match /events/{eventId} {
      allow get: if true;
      allow list: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // STORE ITEMS COLLECTION
    match /store-items/{itemId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}