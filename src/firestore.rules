rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // HELPER FUNCTIONS
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isFireteamMember(fireteamId) {
      return isSignedIn() && get(/databases/$(database)/documents/fireteams/$(fireteamId)).data.members[request.auth.uid] == true;
    }

    function isGuildMember(guildId) {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.guilds[guildId] == true;
    }

    // COLLECTION GROUP QUERY for logs (Verify page)
    match /{path=**}/logs/{logId} {
      allow read: if isSignedIn();
    }

    // ADMINS COLLECTION
    match /admins/{adminId} {
      allow read: if isOwner(adminId) || isAdmin();
      allow write: if isAdmin() || isOwner(adminId);
    }
    
    // USERS COLLECTION
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      // USER SUB-COLLECTIONS
      match /logs/{logId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /quests/{questId} {
         allow read, write: if isOwner(userId) || isAdmin();
      }

      match /settings/{settingsId} {
         allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // PUBLIC LOGS COLLECTION
    match /public-logs/{logId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn(); 
        allow update, delete: if false;
    }

    // SKILLS COLLECTION
    match /skills/{skillId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // FIRETEAMS COLLECTION
    match /fireteams/{fireteamId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isFireteamMember(fireteamId) || isAdmin();
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read, write: if isFireteamMember(fireteamId);
        allow delete: if isAdmin();
      }
    }

    // GUILDS COLLECTION
    match /guilds/{guildId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isGuildMember(guildId) || isAdmin();
      allow delete: if isAdmin();
      
      match /messages/{messageId} {
        allow read, write: if isGuildMember(guildId);
        allow delete: if isAdmin();
      }
    }

    // TERRITORIES COLLECTION
    match /territories/{territoryId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // TRAITS COLLECTION
    match /traits/{traitId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // SUGGESTIONS COLLECTION
    match /suggestions/{suggestionId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // EVENTS COLLECTION
    match /events/{eventId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    
    // STORE ITEMS COLLECTION
    match /store-items/{itemId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}
