
rules_version = '2';

// v1.1 Ruleset: Added public-logs collection
service cloud.firestore {
  match /databases/{database}/documents {

    // HELPER FUNCTIONS

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isFireteamMember(fireteamId) {
      return isSignedIn() && get(/databases/$(database)/documents/fireteams/$(fireteamId)).data.members[request.auth.uid] == true;
    }

    function isGuildMember(guildId) {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.guilds[guildId] == true;
    }

    // ADMINS COLLECTION
    match /admins/{adminId} {
      allow read: if isOwner(adminId) || isAdmin();
      allow write: if isAdmin() || isOwner(adminId);
    }
    
    // USERS COLLECTION
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      // USER SUB-COLLECTIONS (LOGS, QUESTS, SETTINGS)
      match /{subcollection}/{docId} {
        allow read, write, create, update, delete: if isOwner(userId) || isAdmin();
      }
    }

    // PUBLIC LOGS COLLECTION (for "Echoes of the Nebula" feed)
    match /public-logs/{logId} {
        allow get, list: if isSignedIn();
        // Writes should ideally be handled by a trusted backend (e.g., Cloud Function)
        // For now, we allow any signed-in user to create.
        allow create: if isSignedIn(); 
        allow update, delete: if false; // Nobody can update or delete public logs.
    }

    // SKILLS COLLECTION
    match /skills/{skillId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // FIRETEAMS COLLECTION
    match /fireteams/{fireteamId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isFireteamMember(fireteamId) || isAdmin();
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read, write: if isFireteamMember(fireteamId);
        allow delete: if isAdmin();
      }
    }

    // GUILDS COLLECTION
    match /guilds/{guildId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isGuildMember(guildId) || isAdmin();
      allow delete: if isAdmin();
      
      match /messages/{messageId} {
        allow read, write: if isGuildMember(guildId);
        allow delete: if isAdmin();
      }
    }

    // PUBLIC/ADMIN-MANAGED COLLECTIONS
    match /territories/{territoryId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /traits/{traitId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /suggestions/{suggestionId} {
      allow get, list: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /events/{eventId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }
    
    match /store-items/{itemId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}
