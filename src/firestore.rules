
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // HELPER FUNCTIONS
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isFireteamMember(fireteamId) {
      // Correctly check if the user's UID is a key in the members map
      return isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/fireteams/$(fireteamId)).data.members;
    }

    function isGuildMember(guildId) {
      // Correctly check if the guildId is a key in the user's guilds map
      return isSignedIn() && guildId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.guilds;
    }

    // ADMINS COLLECTION
    match /admins/{adminId} {
      allow read, write: if isAdmin();
    }
    
    // USERS COLLECTION & SUB-COLLECTIONS
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      match /logs/{logId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /quests/{questId} {
         allow read, write: if isOwner(userId) || isAdmin();
      }

       match /settings/{settingsId} {
         allow read, write: if isOwner(userId) || isAdmin();
      }
    }
    
    match /{path=**}/logs/{logId} {
      allow read: if isSignedIn();
    }

    // PUBLIC LOGS COLLECTION
    match /public-logs/{logId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn(); 
        allow update, delete: if false;
    }

    // SKILLS COLLECTION
    match /skills/{skillId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // FIRETEAMS COLLECTION
    match /fireteams/{fireteamId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isFireteamMember(fireteamId) || isAdmin();
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read, write: if isFireteamMember(fireteamId);
        allow delete: if isAdmin();
      }
    }

    // GUILDS COLLECTION
    match /guilds/{guildId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isGuildMember(guildId) || isAdmin();
      allow delete: if isAdmin();
      
      match /messages/{messageId} {
        allow read, write: if isGuildMember(guildId);
        allow delete: if isAdmin();
      }
    }
    
    // RADIO BROADCASTS COLLECTION
    match /radio-broadcasts/{broadcastId} {
        allow get, list: if isSignedIn();
        // Writes are handled by the trusted server-side AI flow
        allow write: if false;
    }

    // PUBLIC & ADMIN-MANAGED COLLECTIONS
    match /territories/{territoryId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /traits/{traitId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /suggestions/{suggestionId} {
      allow get, list: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /events/{eventId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }
    
    match /store-items/{itemId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}

    