
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // HELPER FUNCTIONS
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      // Direct check for the bootstrap super-admin to avoid recursion.
      // Other admins are verified by existence in the /admins collection.
      return isSignedIn() && (
        request.auth.uid == "D2q0IIDPXXaXzVRhG1hFURv0Awe2" || 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isFireteamMember(fireteamId) {
      return isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/fireteams/$(fireteamId)).data.members;
    }

    function isGuildMember(guildId) {
      return isSignedIn() && guildId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.guilds;
    }

    // ADMINS COLLECTION
    match /admins/{adminId} {
      // Users can read their own admin status; admins can read all.
      allow read: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
      allow create: if isOwner(adminId);
      allow update, delete: if isAdmin();
    }
    
    // USERS COLLECTION & SUB-COLLECTIONS
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      match /logs/{logId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /quests/{questId} {
         allow read, write: if isOwner(userId) || isAdmin();
      }

       match /settings/{settingsId} {
         allow read, write: if isOwner(userId) || isAdmin();
      }

      match /wardrobe/{avatarId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    match /{path=**}/logs/{logId} {
      allow read: if isSignedIn();
    }

    // PUBLIC LOGS COLLECTION
    match /public-logs/{logId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn(); 
        allow update, delete: if false;
    }

    // SKILLS COLLECTION
    match /skills/{skillId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // FIRETEAMS COLLECTION
    match /fireteams/{fireteamId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isFireteamMember(fireteamId) || isAdmin();
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read, write: if isFireteamMember(fireteamId);
        allow delete: if isAdmin();
      }
    }

    // GUILDS COLLECTION
    match /guilds/{guildId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isGuildMember(guildId) || isAdmin();
      allow delete: if isAdmin();
      
      match /messages/{messageId} {
        allow read, write: if isGuildMember(guildId);
        allow delete: if isAdmin();
      }
    }
    
    // MENTORSHIPS COLLECTION
    match /mentorships/{mentorshipId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.mentorId || request.auth.uid == resource.data.menteeId);
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.menteeId;
      allow update: if isSignedIn() && (request.auth.uid == resource.data.mentorId || request.auth.uid == resource.data.menteeId);
      allow delete: if false;
    }

    // RADIO BROADCASTS COLLECTION
    match /radio-broadcasts/{broadcastId} {
        allow get, list: if isSignedIn();
        allow write: if false;
    }

    // PUBLIC & ADMIN-MANAGED COLLECTIONS
    match /territories/{territoryId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /traits/{traitId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /suggestions/{suggestionId} {
      allow get, list: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /events/{eventId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }
    
    match /store-items/{itemId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}
