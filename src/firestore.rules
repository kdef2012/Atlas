
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // HELPER FUNCTIONS
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isFireteamMember(fireteamId) {
      // Correctly check if the user's UID is a key in the members map
      return isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/fireteams/$(fireteamId)).data.members;
    }

    function isGuildMember(guildId) {
      // Correctly check if the guildId is a key in the user's guilds map
      return isSignedIn() && guildId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.guilds;
    }

    // ADMINS COLLECTION
    match /admins/{adminId} {
      allow read, write: if isAdmin();
    }
    
    // USERS COLLECTION & SUB-COLLECTIONS
    match /users/{userId} {
      // Any signed-in user can read an individual user profile or list the entire collection for leaderboards.
      // This is the key fix: 'read' permission covers both 'get' and 'list'.
      allow read: if isSignedIn();
      
      // A user can create their own profile.
      allow create: if isOwner(userId);
      // A user can update their own profile, or an admin can.
      allow update: if isOwner(userId) || isAdmin();
      // Only admins can delete user accounts.
      allow delete: if isAdmin();

      // USER SUB-COLLECTIONS (LOGS, QUESTS, SETTINGS)
      match /logs/{logId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /quests/{questId} {
         allow read, write: if isOwner(userId) || isAdmin();
      }

       match /settings/{settingsId} {
         allow read, write: if isOwner(userId) || isAdmin();
      }
    }
    
    // --- CRITICAL FIX: EXPLICIT RULE FOR COLLECTION GROUP QUERY ---
    // This rule specifically allows the 'Verify' page to query the 'logs' collection
    // across all users.
    match /{path=**}/logs/{logId} {
      allow read: if isSignedIn();
    }

    // PUBLIC LOGS COLLECTION (for "Echoes of the Nebula" feed)
    match /public-logs/{logId} {
        allow get, list: if isSignedIn();
        // Writes should ideally be handled by a trusted backend (e.g., Cloud Function)
        // This allows any user to create, which is what the app does now.
        allow create: if isSignedIn(); 
        allow update, delete: if false;
    }

    // SKILLS COLLECTION
    match /skills/{skillId} {
      allow get, list: if true; // Skills are public knowledge.
      allow create: if isSignedIn(); // Any user can pioneer a new skill.
      allow update, delete: if isAdmin();
    }

    // FIRETEAMS COLLECTION
    match /fireteams/{fireteamId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isFireteamMember(fireteamId) || isAdmin();
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read, write: if isFireteamMember(fireteamId);
        allow delete: if isAdmin();
      }
    }

    // GUILDS COLLECTION
    match /guilds/{guildId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin(); // Only admins can create guilds.
      allow update: if isGuildMember(guildId) || isAdmin();
      allow delete: if isAdmin();
      
      match /messages/{messageId} {
        allow read, write: if isGuildMember(guildId);
        allow delete: if isAdmin();
      }
    }

    // PUBLIC & ADMIN-MANAGED COLLECTIONS
    match /territories/{territoryId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /traits/{traitId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /suggestions/{suggestionId} {
      allow get, list: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /events/{eventId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }
    
    match /store-items/{itemId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}
