
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Avatars: Publicly viewable, but only writable by the owner.
    match /avatars/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // User Proofs: 
    // STRICT AUTHORIZATION: Explicitly match the path and ensure UID matches.
    match /users/{userId}/proofs/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Catch-all for other user-specific files in their home directory
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
