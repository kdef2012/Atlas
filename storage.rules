
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Avatars: Publicly viewable, but only writable by the owner.
    match /avatars/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // User Proofs: 
    // Specifically structured for activity logging. 
    // Community can read for verification, owner can write.
    match /users/{userId}/proofs/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Catch-all for other user-specific files
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
