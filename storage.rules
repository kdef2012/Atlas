
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Helper to check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to check if user owns the folder
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Avatars: Publicly viewable by all citizens, but only editable by the owner.
    // The wildcard {allPaths=**} ensures that all files within the user's folder are covered.
    match /avatars/{userId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // User Data & Proofs: 
    // Proofs are viewable by others for verification logic.
    match /users/{userId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }
  }
}
