
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Avatars: Publicly viewable by all citizens, but only editable by the owner.
    match /avatars/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // User Data & Proofs: 
    // Proofs are viewable by others for verification logic, but only writable by the owner.
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
